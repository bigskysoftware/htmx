---
import Layout from '../layouts/Layout.astro';
import Demo from '../components/Demo.astro';
import Sidebar from '../components/Sidebar.astro';
import SidebarToggle from '../components/SidebarToggle.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHeader from '../components/PageHeader.astro';
import Pagination from '../components/Pagination.astro';
import CollectionCards from '../components/CollectionCards.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getFolder, COLLECTIONS } from '../lib/content.ts';

export async function getStaticPaths() {
    const paths = [];

    for (const collection of COLLECTIONS) {
        const isHome = collection === 'home';
        const folder = await getFolder(collection);

        paths.push({
            params: { slug: isHome ? undefined : collection },
            props: { folder, collection }
        });

        folder.allFiles.forEach((file) => {
            paths.push({
                params: { slug: isHome ? file.slug : `${collection}/${file.slug}` },
                props: { file, folder, collection }
            });
        });
    }

    return paths;
}

const { file, folder, collection } = Astro.props;

const isCollectionRootPage = !file;
const isHomePage = isCollectionRootPage && collection === 'home';
const page = isCollectionRootPage ? folder! : file;

const {Content} = await page.render();
const {title, description, keywords} = page.frontmatter;

let headings: any[] = [];
if (file) {
    const rendered = await file.render();
    headings = rendered.headings;
}

// Display flags
const includeSidebar = !!(folder?.subfolders?.length);
const includeHeader = !isHomePage;
const includeDemo = !isCollectionRootPage && collection === 'patterns';
const includeCollectionCards = isCollectionRootPage && ['docs', 'reference'].includes(collection);
const includeTableOfContents = !isCollectionRootPage && headings.length > 0;
const includePagination = !isCollectionRootPage && !!(file?.prev || file?.next);
const includeAside = includeTableOfContents || includePagination;
const useWideLayout = isCollectionRootPage && ['about', 'docs', 'reference', 'patterns'].includes(collection);
---

<Layout title={title}
        description={description}
        keywords={keywords}
        type={!isCollectionRootPage ? 'article' : undefined}
        publishedTime={file?.frontmatter.created}
        modifiedTime={file?.frontmatter.modified}
        authors={file?.frontmatter.authors}
        articleTags={file?.frontmatter.tags}>

    <Header slot="header">
        {includeSidebar && <SidebarToggle />}
    </Header>

    {includeSidebar && <Sidebar folder={folder} file={file}/>}

    <div id="content-wrapper" class:list={[includeSidebar && "lg:pl-72"]}>
        <main id="content-main-content" class="flex-1">
            <div class="w-full mx-auto px-4 sm:px-6 lg:px-8 flex justify-center max-w-360">

                <div class:list={["pt-6 sm:pt-8 lg:pt-12 flex-1 w-full relative starting:opacity-0 delay-150 transition", useWideLayout ? 'max-w-4xl' : 'max-w-prose']}>
                    <Breadcrumbs breadcrumbs={page.breadcrumbs} />

                    {includeHeader && <PageHeader {title} {description} {file} {collection} />}

                    <article class="prose prose-htmx prose-sm sm:prose-base dark:prose-invert max-w-none">
                        {includeDemo && <Demo />}
                        <Content/>
                        {includePagination && <Pagination prev={file!.prev} next={file!.next} />}
                    </article>
                    {includeCollectionCards && <CollectionCards folders={folder!.subfolders.sort((a, b) => a.id.localeCompare(b.id))} {collection} />}
                </div>

                {includeAside && (
                        <aside class:list={[
                            "hidden xl:flex xl:flex-col xl:w-60 shrink-0 xl:ml-16 self-start sticky top-(--header-height) h-[calc(100vh-var(--header-height))] pt-27 pb-8 pr-4",
                            includeSidebar ? "xl:-me-16" : "xl:-me-[19rem]",
                        ]}>
                            {includePagination && (
                                    <div class:list={["shrink-0", includeTableOfContents && "mb-8"]}>
                                        <Pagination prev={file!.prev} next={file!.next} variant="compact" />
                                    </div>
                            )}
                            {includeTableOfContents && (
                                    <>
                                        <div class="shrink-0 mb-2">
                                            <h2 class="text-[0.675rem] font-sans tracking-wide uppercase text-neutral-500">
                                                On this page
                                            </h2>
                                        </div>
                                        <div class="flex-1 min-h-0 overflow-hidden">
                                            <div class="h-full overflow-y-auto scrollbar-subtle">
                                                <TableOfContents {headings}/>
                                            </div>
                                        </div>
                                    </>
                            )}
                        </aside>
                )}
            </div>
        </main>
    </div>

    <Footer slot="footer"
            class:list={[includeSidebar && "lg:pl-72"]}
            containerClass="px-4 sm:px-6 lg:px-12 xl:px-8"
            contentClass="mx-auto max-w-4xl"
    />
</Layout>
