---
import type {ContentFolder, ContentFile} from '../lib/content';

interface Props {
    folder: ContentFolder;
    file?: ContentFile;
    /** /docs anchor mode: forces sections open, scrollspy lights up the link for the visible H2. */
    scrollspy?: boolean;
}

const {folder, file, scrollspy = false} = Astro.props;
const currentUrl = Astro.url.pathname;

const isReference = folder.folder === 'reference';
const isPatterns = folder.folder === 'patterns';
---

<aside id="sidebar" class="fixed top-(--header-height) inset-x-0 isolate z-30 group/sidebar">

    <nav id="sidebar-nav" aria-label="Sidebar Navigation" class="
            bg-neutral-25 dark:bg-neutral-920 overflow-y-auto border-neutral-200 dark:border-neutral-850 transition
            px-3 sm:px-5 lg:px-6
            pb-10
            max-lg:absolute max-lg:top-full max-lg:inset-x-0 max-lg:z-30
            max-lg:h-[calc(100lvh-var(--header-height))]
            max-lg:overscroll-contain
            max-lg:opacity-0 max-lg:pointer-events-none max-lg:duration-200
            [html:has(#sidebar-toggle-mobile:checked)_&]:opacity-100 [html:has(#sidebar-toggle-mobile:checked)_&]:pointer-events-auto
            lg:fixed lg:top-(--header-height) lg:left-0 lg:bottom-0 lg:w-[320px] lg:border-r
         ">

        <div class="h-7 shrink-0"></div>

        <div class="flex items-center justify-between gap-2 px-0.5 mb-6">
            <h2 class="font-sans text-xs font-medium uppercase tracking-widest text-neutral-600 dark:text-neutral-400">
                {folder.frontmatter.title}
            </h2>
            {!scrollspy && folder.folders.length > 1 && (
                    <div class="flex items-center gap-0.5 text-neutral-400 dark:text-neutral-500">
                        <button type="button"
                                title="Expand all sections"
                                aria-label="Expand all sections"
                                class="p-1 rounded interact:bg-neutral-100 dark:interact:bg-neutral-850 interact:text-neutral-700 dark:interact:text-neutral-200 cursor-pointer"
                                _="on click for d in <#sidebar-nav details/> set d.open to true">
                            <i class="icon-[mdi--unfold-more-horizontal] size-4 block" aria-hidden="true"></i>
                        </button>
                        <button type="button"
                                title="Collapse all sections"
                                aria-label="Collapse all sections"
                                class="p-1 rounded interact:bg-neutral-100 dark:interact:bg-neutral-850 interact:text-neutral-700 dark:interact:text-neutral-200 cursor-pointer"
                                _="on click for d in <#sidebar-nav details/> set d.open to false">
                            <i class="icon-[mdi--unfold-less-horizontal] size-4 block" aria-hidden="true"></i>
                        </button>
                    </div>
            )}
        </div>

        <div class="border-l border-neutral-200 dark:border-neutral-800"
             _={scrollspy ? `def setupSidebarSpy()
                    wait 50ms
                    set allH2s to <main h2[id]/> as Array
                    js(me, allH2s)
                        if (me._sidebarObserver) me._sidebarObserver.disconnect();
                        const observer = new IntersectionObserver(
                            (entries) => entries.forEach(entry => {
                                if (!entry.isIntersecting) return;
                                const id = entry.target.getAttribute('id');
                                const link = me.querySelector('.sidebar-link[href$="#' + id + '"]');
                                if (link) {
                                    _hyperscript.evaluate(
                                        "take [@data-active] from .sidebar-link for first <.sidebar-link[href$='#" + id + "']/>"
                                    );
                                    var pageY = window.scrollY;
                                    link.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                                    window.scrollTo(0, pageY);
                                }
                            }),
                            { rootMargin: '-100px 0px -66% 0px', threshold: 0 }
                        );
                        allH2s.forEach(h => observer.observe(h));
                        me._sidebarObserver = observer;
                    end
                    init call setupSidebarSpy() end
                    on htmx:after:swap from document call setupSidebarSpy() end` : undefined}>

            {!scrollspy && (
                    <a href={folder.url}
                       data-active={currentUrl === folder.url ? '' : undefined}
                       class="sidebar-link block py-2 pl-4 pr-3 text-sm truncate -ml-px border-l-2 border-transparent text-neutral-600 dark:text-neutral-400 interact:text-neutral-900 dark:interact:text-neutral-200 interact:border-neutral-300 dark:interact:border-neutral-700 data-active:border-neutral-900 dark:data-active:border-neutral-100 data-active:text-neutral-900 dark:data-active:text-neutral-100 data-active:font-semibold">
                        Overview
                    </a>
            )}

            {folder.folders.map((subFolder) => {
                const files = subFolder.files;
                const containsCurrentPage = files.some((f: ContentFile) => currentUrl === f.url);

                return (
                        <details class="group/section w-full mt-3 no-morph"
                                 open={scrollspy || containsCurrentPage}>
                            <summary class="
                                       list-none select-none cursor-pointer pl-4 pr-3 py-1
                                       flex items-center justify-between gap-2
                                       [&::-webkit-details-marker]:hidden
                                       text-neutral-500 dark:text-neutral-500
                                       interact:text-neutral-700 dark:interact:text-neutral-300">

                                <h3 class:list={[
                                    "font-sans text-[0.625rem] tracking-widest uppercase truncate min-w-0 text-neutral-600 dark:text-neutral-400",
                                    containsCurrentPage && "text-neutral-700 dark:text-neutral-300"
                                ]}
                                    set:html={subFolder.frontmatter.title}/>
                                {!scrollspy && (
                                        <i class="icon-[mdi--chevron-down] size-4 transition group-open/section:rotate-180 text-neutral-400 dark:text-neutral-500 shrink-0"></i>
                                )}
                            </summary>

                            {files.length > 0 && (
                                    <ul class="mt-1 mb-2">
                                        {files.map((file: ContentFile) => {
                                            const isActive = currentUrl === file.url;
                                            const isSoon = file.frontmatter.soon;
                                            return (
                                                    <li>
                                                        <a href={isSoon ? undefined : file.url}
                                                           title={file.frontmatter.description}
                                                           aria-current={isActive ? 'page' : undefined}
                                                           aria-disabled={isSoon ? 'true' : undefined}
                                                           hx-boost={isSoon && 'false'}
                                                           data-active={isActive ? '' : undefined}
                                                           class:list={[
                                                               'sidebar-link flex items-center gap-2.5 py-2 pl-4 pr-3 text-sm -ml-px border-l-2 border-transparent text-neutral-600 dark:text-neutral-400 interact:text-neutral-900 dark:interact:text-neutral-200 interact:border-neutral-300 dark:interact:border-neutral-700 data-active:border-neutral-900 dark:data-active:border-neutral-100 data-active:text-neutral-900 dark:data-active:text-neutral-100 data-active:font-semibold',
                                                               isReference && 'font-mono',
                                                               isSoon && 'opacity-50 cursor-not-allowed text-neutral-400 dark:text-neutral-400',
                                                           ]}>
                                                            {isPatterns && file.frontmatter.icon && (
                                                                    <i class:list={[file.frontmatter.icon, "size-4 shrink-0"]}></i>
                                                            )}
                                                            <span class="truncate" set:html={file.frontmatter.title}/>
                                                            {isSoon && (
                                                                    <span class="text-[9px] px-1.5 py-0.5 shrink-0 rounded bg-yellow-300/5 text-yellow-700 dark:text-yellow-300 border border-yellow-600/50 dark:border-yellow-300 font-medium uppercase tracking-wide ml-auto">Soon</span>
                                                            )}
                                                        </a>
                                                    </li>
                                            );
                                        })}
                                    </ul>
                            )}
                        </details>
                );
            })}

            {folder.files.map((f: ContentFile) => {
                const isActive = currentUrl === f.url;
                return (
                        <a href={f.url}
                           title={f.frontmatter.description}
                           aria-current={isActive ? 'page' : undefined}
                           data-active={isActive ? '' : undefined}
                           class="sidebar-link block py-2 pl-4 pr-3 text-sm truncate -ml-px border-l-2 border-transparent text-neutral-600 dark:text-neutral-400 interact:text-neutral-900 dark:interact:text-neutral-200 interact:border-neutral-300 dark:interact:border-neutral-700 data-active:border-neutral-900 dark:data-active:border-neutral-100 data-active:text-neutral-900 dark:data-active:text-neutral-100 data-active:font-semibold">
                            <span set:html={f.frontmatter.title}/>
                        </a>
                );
            })}
        </div>
    </nav>

    <input id="sidebar-toggle-mobile" type="checkbox" class="sr-only" _="on click from <a/> set my.checked to false">
</aside>
