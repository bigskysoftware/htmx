---
import {getFolder} from '../lib/content';
import {formatDate} from '../lib/utils';
import LinkList from './LinkList.astro';

interface Props {
    limit?: number;
    featured?: boolean;
}

const {limit, featured = false} = Astro.props;
const folder = await getFolder('essays');

const essays = folder.subfiles
    .filter(f => f.frontmatter.title)
    .sort((a, b) => {
        const dateA = new Date(a.frontmatter.created || 0);
        const dateB = new Date(b.frontmatter.created || 0);
        return dateB.getTime() - dateA.getTime();
    });

const featuredEssay = featured ? essays[0] : null;
const restEssays = featured ? essays.slice(1) : essays;

const items = restEssays.map(essay => ({
    title: essay.frontmatter.title,
    url: essay.url,
    author: essay.frontmatter.authors.join(', '),
    date: formatDate(essay.frontmatter.created),
}));
---

{featuredEssay && (
    <div class="not-prose mb-4">
    <a href={featuredEssay.url}
       class="group/feat flex flex-col no-underline rounded-lg px-5 py-5 sm:px-6 sm:py-6 -mx-2 sm:-mx-3 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 transition interact:bg-blue-700 dark:interact:bg-blue-600 interact:border-blue-700 dark:interact:border-blue-600">

        <span class="flex items-center gap-3 mb-3 sm:mb-4">
            <span class="inline-block text-[9px] font-mono font-medium uppercase tracking-wider px-1.5 py-px rounded bg-blue-200/50 dark:bg-blue-700/50 text-blue-700 dark:text-blue-300 group-interact/feat:bg-white/20 group-interact/feat:text-white transition">Latest</span>
            <span class="flex items-center gap-1.5 text-xs text-neutral-500 group-interact/feat:text-blue-200 transition">
                <span>{featuredEssay.frontmatter.authors.join(', ')}</span>
                {featuredEssay.frontmatter.created && (
                    <>
                        <span aria-hidden="true">&middot;</span>
                        <span class="font-mono tabular-nums">{formatDate(featuredEssay.frontmatter.created)}</span>
                    </>
                )}
            </span>
        </span>

        <span class="block font-chicago text-xl sm:text-2xl leading-tight text-neutral-800 dark:text-neutral-100 transition group-interact/feat:text-white mb-2 sm:mb-3">
            {featuredEssay.frontmatter.title}
        </span>

        {featuredEssay.frontmatter.description && (
            <span class="text-sm sm:text-base text-neutral-600 dark:text-neutral-400 leading-relaxed transition group-interact/feat:text-blue-100 max-w-[65ch] line-clamp-2">
                {featuredEssay.frontmatter.description}
            </span>
        )}

    </a>
    </div>
)}

<LinkList items={items} limit={limit} />
