---
interface Props {
    items: Array<{
        title: string;
        url: string;
        author?: string;
        date?: string;
    }>;
    limit?: number;
}

const {items, limit} = Astro.props;
const hasSlot = Astro.slots.has('default');

const isExternal = (url: string) => url.startsWith('http');

const displayItems = limit ? items.slice(0, limit) : items;
---

<div class="not-prose">
    <div class="flex flex-col">
        {displayItems.map(async (item) => {
            const external = isExternal(item.url);

            return (
                <a href={item.url}
                   {...(external && {target: "_blank", rel: "noopener noreferrer"})}
                   class:list={[
                       "group/link flex items-center gap-3 px-3 py-2 -mx-3 rounded no-underline transition",
                       "text-neutral-800 dark:text-neutral-200",
                       "interact:text-white interact:bg-blue-700 dark:interact:bg-blue-600",
                   ]}>
                    {hasSlot ? (
                        <span class="min-w-0 flex-1">
                            <Fragment set:html={await Astro.slots.render('default', [item])} />
                        </span>
                    ) : (
                        <>
                            <span class="font-chicago text-sm leading-snug truncate min-w-0 flex-1">
                                {item.title}
                            </span>
                            {(item.author || item.date) && (
                                <span class="shrink-0 flex items-center gap-1.5 text-xs text-neutral-400 dark:text-neutral-500 group-interact/link:text-blue-200 transition">
                                    {item.author && <span>{item.author}</span>}
                                    {item.author && item.date && <span aria-hidden="true">&middot;</span>}
                                    {item.date && <span class="font-mono tabular-nums">{item.date}</span>}
                                </span>
                            )}
                        </>
                    )}
                </a>
            );
        })}
    </div>
</div>
