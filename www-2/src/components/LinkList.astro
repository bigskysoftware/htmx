---
interface Props {
    items: Array<{
        title: string;
        url: string;
        author?: string;
        date?: string;
        tags?: string;
        external?: boolean;
    }>;
    limit?: number;
}

const {items, limit} = Astro.props;
const hasSlot = Astro.slots.has('default');

const isExternal = (url: string) => url.startsWith('http');

const displayItems = limit ? items.slice(0, limit) : items;
---

<div class="not-prose">
    <div class="flex flex-col gap-1">
        {displayItems.map(async (item) => {
            const external = item.external ?? isExternal(item.url);

            return (
                <a href={item.url}
                   data-tags={item.tags}
                   {...(external && {target: "_blank", rel: "noopener noreferrer"})}
                    class:list={[
                       "link-list-item",
                       "group/link flex flex-col sm:flex-row sm:items-center gap-0.5 sm:gap-4 px-3 -mx-3 py-2.5 sm:py-2 no-underline rounded-[3px] transition",
                       "text-neutral-800 dark:text-neutral-200",
                       "interact:bg-blue-700 interact:text-white dark:interact:bg-blue-350 dark:interact:text-black",
                   ]}>
                    {hasSlot ? (
                        <span class="min-w-0 flex-1">
                            <Fragment set:html={await Astro.slots.render('default', [item])} />
                        </span>
                    ) : (
                        <>
                            <span class="flex-1 min-w-0 flex items-center gap-2">
                                <span class="text-[13px] sm:text-sm leading-snug truncate">
                                    {item.title}
                                </span>
                                {external && (
                                    <i class="icon-[mdi--open-in-new] size-3 shrink-0 text-neutral-400 group-interact/link:text-blue-200 dark:group-interact/link:text-black transition"
                                       aria-label="External link"></i>
                                )}
                            </span>
                            {(item.author || item.date) && (
                                <span class="shrink-0 flex items-center gap-1.5 sm:gap-3 text-[11px] font-mono tabular-nums text-neutral-500 dark:text-neutral-450 group-interact/link:text-blue-200 dark:group-interact/link:text-black transition">
                                    {item.author && <span>{item.author}</span>}
                                    {item.author && item.date && <span aria-hidden="true">&middot;</span>}
                                    {item.date && <span class="sm:w-[12ch] sm:text-right">{item.date}</span>}
                                </span>
                            )}
                        </>
                    )}
                </a>
            );
        })}
    </div>
</div>
