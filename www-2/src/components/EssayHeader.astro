---
import { getCollection } from 'astro:content';
import { TAG_ORDER } from '../lib/content';

interface Props {
    authors?: string[];
    created?: Date | string;
    modified?: Date | string;
    tags?: string[];
}

const { authors, created: rawCreated, modified: rawModified, tags } = Astro.props;

// Ensure dates are Date objects (frontmatter may pass strings or Dates)
const created = rawCreated ? (rawCreated instanceof Date ? rawCreated : new Date(rawCreated)) : undefined;
const modified = rawModified ? (rawModified instanceof Date ? rawModified : new Date(rawModified)) : undefined;

// Look up author URLs from team.yaml
const team = await getCollection('team');
const authorInfo = (authors || []).map(name => {
    const member = team.find(m => m.data.name === name);
    return { name, url: member?.data.url };
});

// Tag display labels (from shared TAG_ORDER)
const tagLabels: Record<string, string> = Object.fromEntries(
    TAG_ORDER.map(t => [t.tag, t.label])
);

const formatDate = (date: Date) =>
    date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const showModified = modified && created &&
    modified.toDateString() !== created.toDateString();
---

<div class="not-prose mb-8 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-neutral-500 dark:text-neutral-450">
    {/* Authors */}
    {authorInfo.length > 0 && (
        <span class="flex items-center gap-1.5">
            <i class="icon-[mdi--account-outline] size-4 shrink-0" aria-hidden="true"></i>
            {authorInfo.map((author, i) => (
                <>
                    {i > 0 && <span>, </span>}
                    {author.url ? (
                        <a href={author.url}
                           target="_blank"
                           rel="noopener noreferrer"
                           class="interact:text-blue-600 dark:interact:text-blue-400 interact:underline underline-offset-4 transition">
                            {author.name}
                        </a>
                    ) : (
                        <span>{author.name}</span>
                    )}
                </>
            ))}
        </span>
    )}

    {/* Dates */}
    {created && (
        <span class="flex items-center gap-1.5">
            <i class="icon-[mdi--calendar-outline] size-4 shrink-0" aria-hidden="true"></i>
            <time datetime={created.toISOString().slice(0, 10)}>
                {formatDate(created)}
            </time>
            {showModified && (
                <span>
                    (updated <time datetime={modified.toISOString().slice(0, 10)}>{formatDate(modified)}</time>)
                </span>
            )}
        </span>
    )}

    {/* Tags */}
    {tags && tags.length > 0 && (
        <span class="flex items-center gap-1.5">
            <i class="icon-[mdi--tag-outline] size-4 shrink-0" aria-hidden="true"></i>
            {tags.map((tag, i) => (
                <>
                    {i > 0 && <span class="text-neutral-300 dark:text-neutral-700" aria-hidden="true">·</span>}
                    <span>{tagLabels[tag] || tag}</span>
                </>
            ))}
        </span>
    )}
</div>
