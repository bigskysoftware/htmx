---
interface Props {
    svg: string;
}

const {svg} = Astro.props;
---

<div class="thumbnail-svg" set:html={svg}/>

<style is:global>
    .thumbnail-svg {
        height: 100%;

        svg {
            height: 100%;
            width: auto;
        }

        /* Base colors */
        color: var(--color-neutral-400);
        --accent: var(--color-neutral-400);

        @media (prefers-color-scheme: dark) {
            color: var(--color-neutral-600);
            --accent: var(--color-neutral-600);
        }
    }

    /* Hover - detect anchor interaction in parent card */
    .group:has(a:hover, a:focus-visible, a:active) .thumbnail-svg {
        color: var(--color-neutral-400);
        --accent: var(--color-neutral-600);

        @media (prefers-color-scheme: dark) {
            color: var(--color-neutral-500);
            --accent: var(--color-neutral-300);
        }
    }
</style>
