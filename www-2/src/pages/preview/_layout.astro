---
import '../../assets/css/input.css';
import Header from '../../components/Header.astro';
import {getCollection} from 'astro:content';

interface Props {
    title: string;
    collection?: string;
    showSidebar?: boolean;
}

const {title, collection = 'reference', showSidebar = true} = Astro.props;

const colors: Record<string, string> = {
    reference: '#a78bfa', // violet
    examples: '#34d399',  // emerald
    docs: '#60a5fa',      // blue
};

const effectColor = colors[collection] || colors.reference;

// Fetch Real Content
const allReferenceItems = await getCollection('reference');
const items = allReferenceItems.filter(item => {
    const filename = item.id.split('/').pop();
    return !['_index.md', '_index.mdx', 'index.mdx', 'index.mdx'].includes(filename);
});

// Group items by category folder
const groupedItems = items.reduce((acc, item) => {
    const [folder] = item.id.split('/');
    if (!acc[folder]) {
        acc[folder] = [];
    }
    acc[folder].push(item);
    return acc;
}, {});

// Category mapping with order
const categoryMeta = {
    '01-attributes': {title: 'Attributes', active: true, slug: 'attributes'},
    '02-headers': {title: 'Headers', active: false, slug: 'headers'},
    '03-javascript-api': {title: 'JavaScript API', active: false, slug: 'javascript-api'},
    '04-events': {title: 'Events', active: false, slug: 'events'}
};

// Build Reference Children
const referenceChildren = Object.keys(categoryMeta).map(folder => {
    const folderItems = groupedItems[folder] || [];
    folderItems.sort((a, b) => a.data.title.localeCompare(b.data.title));

    return {
        title: categoryMeta[folder].title,
        active: categoryMeta[folder].active,
        slug: categoryMeta[folder].slug,
        children: folderItems.map(item => ({
            title: item.data.title,
            active: false,
            slug: item.slug || item.id.replace(/\.(md|mdx)$/, '')
        }))
    };
});

// Construct Sidebar Items
const sidebarItems = [
    {
        title: 'Reference',
        active: true,
        slug: 'reference', // Main reference page
        children: referenceChildren
    }
];
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width"/>
    <title>{title} - Design Preview</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
          rel="stylesheet">
</head>
<body class="bg-neutral-25 dark:bg-neutral-920 text-neutral-700 dark:text-neutral-300 antialiased font-[family-name:var(--font-sans)] relative z-0"
      style="font-family: 'IBM Plex Sans', sans-serif;">
<Header/>

<div class="flex min-h-screen pt-(--header-height)">
    {showSidebar && (
        <!-- Sidebar (Mocked for Preview) -->
            <aside class="fixed inset-y-0 left-0 top-(--header-height) h-[calc(100vh-var(--header-height))] w-72 border-r border-neutral-200 dark:border-neutral-800 bg-neutral-25 dark:bg-neutral-920 z-40 hidden lg:block overflow-y-auto">
                <nav class="p-8 space-y-10">
                    {sidebarItems.map((section, sectionIdx) => (
                            <div>
                                <h3 class="font-chicago text-base text-neutral-900 dark:text-neutral-100 mb-4 px-3">
                                    <a href={`/${section.slug}`}
                                       class="interact:text-blue-700 dark:interact:text-blue-400 transition-colors">
                                        {section.title}
                                    </a>
                                </h3>
                                <ul class="space-y-1.5">
                                    {section.children?.map((child, childIdx) => {
                                        const hasChildren = child.children && child.children.length > 0;
                                        const inputId = `sidebar-toggle-${sectionIdx}-${childIdx}`;

                                        return (
                                                <li>
                                                    {hasChildren ? (
                                                            <>
                                                                <input type="checkbox" id={inputId} class="peer hidden"
                                                                       checked={child.active}/>
                                                                <div class:list={[
                                                                    "flex items-center justify-between rounded-md text-sm transition-all duration-200 group select-none pr-1",
                                                                    child.active
                                                                        ? "bg-blue-50/50 dark:bg-blue-900/10"
                                                                        : "interact:bg-neutral-100 dark:interact:bg-neutral-800/50"
                                                                ]}>

                                                                    {/* Split Target: Link */}
                                                                    <a href={`/reference/${child.slug}`} class:list={[
                                                                        "flex-1 px-3 py-2 text-neutral-600 dark:text-neutral-400 interact:text-blue-700 dark:interact:text-blue-400 transition-colors font-medium",
                                                                        child.active && "text-blue-700 dark:text-blue-400 font-bold"
                                                                    ]}>
                                                                        {child.title}
                                                                    </a>

                                                                    {/* Split Target: Toggle */}
                                                                    <label for={inputId}
                                                                           class="p-1.5 text-neutral-400 interact:text-neutral-600 dark:interact:text-neutral-200 cursor-pointer peer-checked:[&>i]:rotate-180">
                                                                        <i class="icon-[mdi--chevron-down] transition-transform duration-200 block"></i>
                                                                    </label>
                                                                </div>

                                                                <ul class="hidden peer-checked:block ml-3 mt-1 pl-3 border-l border-neutral-200 dark:border-neutral-800 space-y-0.5">
                                                                    {child.children.map(sub => (
                                                                            <li>
                                                                                <a href={`/reference/${sub.slug}`}
                                                                                   class:list={[
                                                                                       "block px-3 py-1.5 rounded-md text-sm transition-colors font-medium",
                                                                                       sub.active
                                                                                           ? "text-blue-700 dark:text-blue-400 font-bold bg-blue-100/50 dark:bg-blue-900/20"
                                                                                           : "text-neutral-500 dark:text-neutral-500 interact:text-neutral-900 dark:interact:text-neutral-300 interact:translate-x-1 transition-transform"
                                                                                   ]}>
                                                                                    {sub.title}
                                                                                </a>
                                                                            </li>
                                                                    ))}
                                                                </ul>
                                                            </>
                                                    ) : (
                                                            <div class:list={[
                                                                "flex items-center justify-between px-3 py-2 rounded-md text-sm transition-all duration-200 cursor-pointer group",
                                                                child.active
                                                                    ? "text-blue-700 dark:text-blue-400 font-bold bg-blue-50/50 dark:bg-blue-900/10"
                                                                    : "text-neutral-600 dark:text-neutral-400 interact:text-neutral-900 dark:interact:text-neutral-200 interact:bg-neutral-100 dark:interact:bg-neutral-800/50"
                                                            ]}>
                                                                <span class={child.active ? "translate-x-0.5" : "group-hover:translate-x-0.5 transition-transform"}>{child.title}</span>
                                                            </div>
                                                    )}
                                                </li>
                                        );
                                    })}
                                </ul>
                            </div>
                    ))}
                </nav>
            </aside>
    )}

    <!-- Main Content Wrapper -->
    <div class:list={["flex-1 w-full", showSidebar && "lg:pl-72"]}>
        <main class:list={["w-full mx-auto", showSidebar ? "px-8 py-12 sm:px-12 sm:py-16 lg:px-16 lg:py-20 max-w-4xl" : ""]}>
            <slot/>
        </main>
    </div>
</div>

</body>
</html>