---
import Layout from '../../_layout.astro';

const attributes = [
    {name: 'hx-boost', desc: 'Add or remove progressive enhancement for links and forms'},
    {name: 'hx-get', desc: 'Issues a GET request to the given URL'},
    {name: 'hx-post', desc: 'Issues a POST request to the given URL'},
    {name: 'hx-on*', desc: 'Handle events with inline scripts'},
    {name: 'hx-push-url', desc: 'Pushes a new URL into the history stack'},
    {name: 'hx-select', desc: 'Select content to swap in from a response'},
    {name: 'hx-select-oob', desc: 'Select content to swap in from a response, out of band'},
    {name: 'hx-swap', desc: 'Controls how the content is swapped in'},
    {name: 'hx-swap-oob', desc: 'Marks content in a response to be out of band'},
    {name: 'hx-target', desc: 'Specifies the target element to be swapped'},
    {name: 'hx-trigger', desc: 'Specifies the event that triggers the request'},
    {name: 'hx-vals', desc: 'Adds values to the parameters to be submitted with the request'},
];
---

<Layout title="Attributes - Reference">
    {/* Page Header */}
    <header class="mb-16 border-b border-neutral-200 dark:border-neutral-800 pb-12">
        {/* Breadcrumbs Path */}
        <nav class="flex items-center gap-3 mb-8">
            <a href="/preview/reference"
               class="flex items-center gap-2 text-violet-600 dark:text-violet-400 font-bold text-xs uppercase tracking-widest hover:text-violet-800 transition-colors">
                <i class="icon-[mdi--library-shelves] text-sm"></i>
                <span>Reference</span>
            </a>

            <span class="text-neutral-300 dark:text-neutral-700">/</span>
        </nav>

        <h1 class="font-chicago font-bold text-2xl sm:text-3xl text-neutral-900 dark:text-neutral-100 mb-6 tracking-tight">
            Attributes
        </h1>
        <p class="text-lg text-neutral-600 dark:text-neutral-400 max-w-3xl leading-relaxed">
            htmx attributes allow you to specify AJAX requests, trigger events, and control how content is swapped into
            the DOM directly in HTML.
        </p>
    </header>

    {/* Attributes Table */}
    <div class="border border-neutral-200 dark:border-neutral-800 rounded-lg overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-neutral-50 dark:bg-neutral-900 border-b border-neutral-200 dark:border-neutral-800">
                <tr>
                    <th class="px-6 py-4 font-bold text-neutral-900 dark:text-neutral-100 w-48 font-sans">Attribute</th>
                    <th class="px-6 py-4 font-bold text-neutral-900 dark:text-neutral-100 font-sans">Description</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-neutral-200 dark:divide-neutral-800 bg-white dark:bg-neutral-950">
                {attributes.map(attr => (
                        <tr class="group hover:bg-neutral-50 dark:hover:bg-neutral-900/50 transition-colors">
                            <td class="px-6 py-4">
                                <a href="/preview/reference/attributes/hx-get"
                                   class="font-mono font-bold text-blue-600 dark:text-blue-350 group-hover:underline decoration-2 underline-offset-2">
                                    {attr.name}
                                </a>
                            </td>
                            <td class="px-6 py-4 text-neutral-600 dark:text-neutral-400 font-sans">
                                {attr.desc}
                            </td>
                        </tr>
                ))}
                </tbody>
            </table>
        </div>
    </div>
</Layout>