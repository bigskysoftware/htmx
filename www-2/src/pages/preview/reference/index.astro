---
import {getCollection} from 'astro:content';
import Layout from './../_layout.astro';
import BackgroundEffect from './../_BackgroundEffect.astro';

// Fetch Content
const allReferenceItems = await getCollection('reference');
const items = allReferenceItems.filter(item => {
    const filename = item.id.split('/').pop();
    // Strictly exclude index filenames, checking for with and without extension
    return !filename.match(/^(_)?index(\.(md|mdx))?$/);
});

// Define Categories Metadata
const categoryMeta = {
    '01-attributes': {
        title: 'Attributes',
        icon: 'icon-[mdi--code-tags]',
        description: 'Add to your HTML to make requests and swap content.',
        preview: ['hx-get', 'hx-swap', 'hx-target', "hx-trigger"],
        order: 1
    },
    '02-headers': {
        title: 'Headers',
        icon: 'icon-[mdi--swap-horizontal]',
        description: 'Inspect request context and control responses from your server.',
        preview: ['HX-Request', 'HX-Boosted', 'HX-Trigger'],
        order: 2
    },
    '03-javascript-api': {
        title: 'JavaScript API',
        icon: 'icon-[mdi--function-variant]',
        description: 'Control htmx programmatically from your scripts.',
        preview: ['htmx.ajax()', 'htmx.process()', 'htmx.trigger()'],
        order: 3
    },
    '04-events': {
        title: 'Events',
        icon: 'icon-[mdi--flash]',
        description: 'Hook into the request lifecycle with event listeners.',
        preview: ['htmx:before:request', 'htmx:before:response', 'htmx:before:response'],
        order: 4
    }
};

// Group items by category folder
const groupedItems = items.reduce((acc, item) => {
    const [folder] = item.id.split('/');
    if (!acc[folder]) {
        acc[folder] = [];
    }
    acc[folder].push(item);
    return acc;
}, {});

// Transform into array for rendering, sorted by defined order
const categories = Object.keys(groupedItems)
    .filter(folder => categoryMeta[folder]) // Only show known categories
    .map(folder => ({
        ...categoryMeta[folder],
        slug: folder,
        items: groupedItems[folder].sort((a, b) => a.data.title.localeCompare(b.data.title))
    }))
    .sort((a, b) => a.order - b.order);
---

<Layout title="Reference">
    {/* Page Header */}
    <header class="mb-10">
        <h1 class="font-bold text-3xl text-neutral-900 dark:text-neutral-100 mb-2">
            Reference
        </h1>
        <p class="text-lg text-neutral-500 dark:text-neutral-400">
            Browse the attributes, headers & events that power htmx.
        </p>
    </header>

    {/* Category Cards */}
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {categories.map(category => (
                <a href={`/reference/${category.slug}`}
                   class="group relative flex flex-col p-6 rounded-2xl border border-neutral-200 dark:border-neutral-800 overflow-hidden interact:border-blue-400 dark:interact:border-blue-600 transition-all outline-hidden focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-600 dark:focus-visible:ring-blue-400 min-h-44">
                    <div class="opacity-40 group-interact:opacity-100 transition-opacity duration-300">
                        <BackgroundEffect color="#3b82f6" id={category.slug}/>
                    </div>

                    <div class="relative flex-1 flex flex-col">
                        {/* Header row - icon + browse hint */}
                        <div class="flex items-start justify-between mb-4">
                            <div class="flex items-center justify-center size-14 rounded-2xl bg-white/90 dark:bg-neutral-850 text-neutral-400 dark:text-neutral-500 group-interact:bg-blue-100 dark:group-interact:bg-blue-900/50 group-interact:text-blue-600 dark:group-interact:text-blue-400 transition-colors shadow-sm">
                                <i class={`${category.icon} text-3xl`}></i>
                            </div>
                            <span class="flex items-center gap-1 text-sm font-medium text-blue-600 dark:text-blue-400 opacity-0 group-interact:opacity-100 transition-opacity">
                                Browse
                                <i class="icon-[mdi--arrow-right]"></i>
                            </span>
                        </div>

                        {/* Content */}
                        <h2 class="font-bold text-xl text-neutral-900 dark:text-neutral-100 group-interact:text-blue-600 dark:group-interact:text-blue-400 transition-colors mb-2">
                            {category.title}
                        </h2>
                        <p class="text-base text-neutral-500 dark:text-neutral-400 leading-relaxed">
                            {category.description}
                        </p>

                        {/* Preview items */}
                        <p class="text-sm font-mono text-neutral-400 dark:text-neutral-600 mt-3 line-clamp-2">
                            {category.preview.join(', ')}...
                        </p>
                    </div>
                </a>
        ))}

        {/* Extensions Card (Full Width) */}
        <a href="/docs/extensions"
           class="group relative flex flex-col p-5 rounded-2xl border border-neutral-200 dark:border-neutral-800 overflow-hidden interact:border-blue-400 dark:interact:border-blue-600 transition-all outline-hidden focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-600 dark:focus-visible:ring-blue-400 min-h-36 sm:col-span-2">
            <div class="opacity-40 group-interact:opacity-100 transition-opacity duration-300">
                <BackgroundEffect color="#3b82f6" id="extensions"/>
            </div>

            <div class="relative flex-1 flex flex-col justify-between">
                <div class="flex items-start justify-between mb-2">
                    <div class="flex items-center gap-4">
                        <div class="flex items-center justify-center size-10 rounded-xl bg-white/90 dark:bg-neutral-850 text-neutral-400 dark:text-neutral-500 group-interact:bg-blue-100 dark:group-interact:bg-blue-900/50 group-interact:text-blue-600 dark:group-interact:text-blue-400 transition-colors shadow-sm">
                            <i class="icon-[mdi--puzzle] text-xl"></i>
                        </div>
                        <h2 class="font-bold text-xl text-neutral-900 dark:text-neutral-100 group-interact:text-blue-600 dark:group-interact:text-blue-400 transition-colors">
                            Extensions
                        </h2>
                    </div>

                    <span class="flex items-center gap-1 text-sm font-medium text-blue-600 dark:text-blue-400 opacity-0 group-interact:opacity-100 transition-opacity">
                        Explore
                        <i class="icon-[mdi--arrow-right]"></i>
                    </span>
                </div>

                <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-2">
                    <p class="text-base text-neutral-500 dark:text-neutral-400 leading-relaxed">
                        Add powerful community-driven features like WebSockets and SSE.
                    </p>
                    <p class="text-xs font-mono text-neutral-400 dark:text-neutral-600 line-clamp-1">
                        head-support, hx-ws, hx-sse, class-tools...
                    </p>
                </div>
            </div>
        </a>
    </div>

    {/* Prose Content */}
    <div class="mt-8 max-w-2xl mx-auto text-center">
        <p class="text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed">
            The reference section covers the core API surface of htmx. For a guided introduction, check out the <a
                href="/docs" class="text-blue-600 dark:text-blue-400 hover:underline underline-offset-2 font-medium">documentation</a>,
            or see practical use-cases in the <a href="/examples"
                                                 class="text-blue-600 dark:text-blue-400 hover:underline underline-offset-2 font-medium">examples</a>
            gallery.
        </p>
    </div>

    {/* Separator */}
    <hr class="mt-12 mb-10 border-neutral-200 dark:border-neutral-800"/>

    {/* Search Hint */}
    <div class="mt-12 flex justify-center">
        <button
                class="group inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-transparent hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors text-sm text-neutral-400 dark:text-neutral-500 cursor-pointer"
                onclick="document.querySelector('[aria-label=Search]').click()"
        >
            <i class="icon-[mdi--magnify] group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors"></i>
            <span>Press</span>
            <kbd
                    class="min-w-[20px] text-center px-1 rounded bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 font-sans text-xs font-medium text-neutral-500 dark:text-neutral-400 group-hover:border-neutral-300 dark:group-hover:border-neutral-600 transition-colors"
                    _="init if navigator.platform.toLowerCase() contains 'mac' put '⌘K' into me else put 'Ctrl K' into me"
            >Ctrl K</kbd>
            <span>to search reference</span>
        </button>
    </div>
</Layout>
