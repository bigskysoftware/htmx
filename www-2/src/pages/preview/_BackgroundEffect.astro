---
interface Props {
  color?: string;
  id?: string;
}

const { color = '#a78bfa', id = 'default' } = Astro.props;
const htmxBlue = '#3b82f6';
const gridFadeId = `grid-fade-${id}`;
const fadeMaskId = `fade-mask-${id}`;
const maskGradientId = `mask-gradient-${id}`;
---

<div class="absolute inset-0 -z-10 overflow-hidden select-none rounded-xl" aria-hidden="true">

    <!-- SVG Retro Grid -->
    <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <defs>
            <linearGradient id={gridFadeId} x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color={htmxBlue} stop-opacity="0.3" />
                <stop offset="100%" stop-color={color} stop-opacity="0.3" />
            </linearGradient>

            <mask id={fadeMaskId}>
                <radialGradient id={maskGradientId} cx="100%" cy="0%" r="1.2">
                    <stop offset="0%" stop-color="white" stop-opacity="1" />
                    <stop offset="40%" stop-color="white" stop-opacity="0.8" />
                    <stop offset="100%" stop-color="black" stop-opacity="0" />
                </radialGradient>
                <rect width="100%" height="100%" fill={`url(#${maskGradientId})`} />
            </mask>
        </defs>

        <!-- Perspective Grid Group -->
        <g mask={`url(#${fadeMaskId})`}>
            <!-- Vertical Lines (Perspective fan) -->
            <path d="M50% -50% L-20% 120%" stroke={`url(#${gridFadeId})`} stroke-width="1" vector-effect="non-scaling-stroke" />
            <path d="M50% -50% L0% 120%" stroke={`url(#${gridFadeId})`} stroke-width="1" vector-effect="non-scaling-stroke" />
            <path d="M50% -50% L20% 120%" stroke={`url(#${gridFadeId})`} stroke-width="1" vector-effect="non-scaling-stroke" />
            <path d="M50% -50% L40% 120%" stroke={`url(#${gridFadeId})`} stroke-width="1" vector-effect="non-scaling-stroke" />
            <path d="M50% -50% L60% 120%" stroke={`url(#${gridFadeId})`} stroke-width="1" vector-effect="non-scaling-stroke" />
            <path d="M50% -50% L80% 120%" stroke={`url(#${gridFadeId})`} stroke-width="1" vector-effect="non-scaling-stroke" />
            <path d="M50% -50% L100% 120%" stroke={`url(#${gridFadeId})`} stroke-width="1" vector-effect="non-scaling-stroke" />
            <path d="M50% -50% L120% 120%" stroke={`url(#${gridFadeId})`} stroke-width="1" vector-effect="non-scaling-stroke" />

             <!-- Horizontal Lines -->
             <line x1="0" y1="10%" x2="100%" y2="10%" stroke={color} stroke-width="1" stroke-opacity="0.1" />
             <line x1="0" y1="25%" x2="100%" y2="25%" stroke={color} stroke-width="1" stroke-opacity="0.15" />
             <line x1="0" y1="45%" x2="100%" y2="45%" stroke={color} stroke-width="1" stroke-opacity="0.2" />
             <line x1="0" y1="70%" x2="100%" y2="70%" stroke={color} stroke-width="1" stroke-opacity="0.25" />
             <line x1="0" y1="100%" x2="100%" y2="100%" stroke={color} stroke-width="1" stroke-opacity="0.3" />
        </g>
    </svg>

    <!-- Top Horizon Line -->
    <div class="absolute top-0 inset-x-0 h-px opacity-60"
         style={`background: linear-gradient(to right, transparent 30%, ${htmxBlue}, ${color} 90%, transparent);`}>
    </div>
    
    <!-- Accent Glow -->
    <div class="absolute top-0 right-0 w-2/3 h-full opacity-[0.06] mix-blend-screen"
         style={`background: radial-gradient(circle at 100% 0%, ${color}, transparent 70%);`}>
    </div>
</div>
