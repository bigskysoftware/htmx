---
import {getFolder} from '../../lib/content';
import {formatDate} from '../../lib/utils';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import LinkList from '../../components/LinkList.astro';

const folder = await getFolder('essays');

const essays = folder.subfiles
    .filter(f => f.frontmatter.title)
    .sort((a, b) => {
        const dateA = new Date(a.frontmatter.created || 0);
        const dateB = new Date(b.frontmatter.created || 0);
        return dateB.getTime() - dateA.getTime();
    });

// Group by year
const grouped = new Map<string, typeof essays>();
for (const essay of essays) {
    const year = essay.frontmatter.created
        ? new Date(essay.frontmatter.created).getFullYear().toString()
        : 'Undated';
    if (!grouped.has(year)) grouped.set(year, []);
    grouped.get(year)!.push(essay);
}
---

<Layout title="All Essays" description="Every htmx essay, chronologically.">
    <div class="w-full mx-auto px-4 sm:px-6 lg:px-8 flex justify-center max-w-[1440px]">
        <div class="pt-8 sm:pt-12 flex-1 w-full max-w-prose">

            <Breadcrumbs breadcrumbs={[
                {label: 'Essays', href: '/essays'},
                {label: 'All'},
            ]} />

            <h1 class="font-chicago text-2xl sm:text-3xl text-neutral-900 dark:text-neutral-100">All Essays</h1>
            <p class="text-neutral-600 dark:text-neutral-400 mt-4 mb-12">Every essay we've published, grouped by year.</p>

            <div class="space-y-10">
                {[...grouped.entries()].map(([year, yearEssays]) => (
                    <section>
                        <h2 class="font-sans text-xs font-medium uppercase tracking-widest text-neutral-550 dark:text-neutral-450 mb-4">{year}</h2>
                        <LinkList items={yearEssays.map(e => ({
                            title: e.frontmatter.title,
                            url: e.url,
                            author: e.frontmatter.authors.join(', '),
                            date: formatDate(e.frontmatter.created),
                        }))} />
                    </section>
                ))}
            </div>

            <div class="h-16"></div>
        </div>
    </div>
</Layout>
