---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import {getFolder} from '../../lib/content';
import {formatDate} from '../../lib/utils';

const folder = await getFolder('essays');

const essays = folder.subfiles
    .filter(f => f.frontmatter.title)
    .sort((a, b) => {
        const dateA = new Date(a.frontmatter.created || 0);
        const dateB = new Date(b.frontmatter.created || 0);
        return dateB.getTime() - dateA.getTime();
    });

const featured = essays[0];

// Tag definitions — labels match the old curated groupings
const tagDefs = [
    {id: 'all', label: 'All'},
    {id: 'foundations', label: 'Hypermedia & REST'},
    {id: 'the-case-for-hypermedia', label: 'Why Hypermedia?'},
    {id: 'case-studies', label: 'The Real World'},
    {id: 'guides', label: 'Building HDAs'},
    {id: 'simplicity', label: 'Complexity Bad'},
    {id: 'counterpoints', label: 'On The Other Hand'},
    {id: 'research', label: 'Research'},
] as const;

// External links from the old curated lists
const externalLinks = [
    // Hypermedia & REST
    {title: "HATEOAS Is For Humans", url: "https://intercoolerjs.org/2016/05/08/hatoeas-is-for-humans.html", author: "Carson Gross", date: "2016-05-08", tags: "foundations"},
    {title: "Taking HTML Seriously", url: "https://intercoolerjs.org/2020/01/14/taking-html-seriously", author: "Carson Gross", date: "2020-01-14", tags: "foundations"},
    // Why Hypermedia?
    {title: "The API Churn/Security Trade-off", url: "https://intercoolerjs.org/2016/02/17/api-churn-vs-security.html", author: "Carson Gross", date: "2016-02-17", tags: "the-case-for-hypermedia"},
    // On The Other Hand
    {title: "A Modest Critique of htmx", url: "https://chrisdone.com/posts/htmx-critique/", author: "Chris Done", date: "2024-10-01", tags: "counterpoints"},
    {title: "A Modest Critique of htmx (Response)", url: "https://news.ycombinator.com/item?id=41782080", author: "", date: "2024-10-01", tags: "counterpoints"},
    {title: "I tried HTMX, then ditched it", url: "https://ajmoon.com/posts/mesh-i-tried-htmx-then-ditched-it", author: "AJ Moon", date: "", tags: "counterpoints"},
    // Building HDAs
    {title: "Is Rendering JSON More Efficient Than HTML?", url: "https://github.com/1cg/html-json-speed-comparison", author: "Carson Gross", date: "", tags: "guides"},
    {title: "Is JSON Smaller Than HTML?", url: "https://github.com/1cg/html-json-size-comparison", author: "Carson Gross", date: "", tags: "guides"},
    // Complexity Bad
    {title: "The Grug Brained Developer", url: "https://grugbrain.dev", author: "Carson Gross", date: "", tags: "simplicity"},
    {title: "htmx Implementation Deep Dive", url: "https://www.youtube.com/watch?v=javGxN-h9VQ", author: "Carson Gross", date: "", tags: "simplicity"},
    // Research
    {title: "A File Structure For The Complex, The Changing and the Indeterminate", url: "https://dl.acm.org/doi/pdf/10.1145/800197.806036", author: "Ted Nelson", date: "1965-01-01", tags: "research"},
    {title: "The Mother Of All Demos", url: "https://www.youtube.com/watch?v=B6rKUf9DWRI", author: "Doug Engelbart", date: "1968-01-01", tags: "research"},
    {title: "The First Web Page", url: "http://info.cern.ch/hypertext/WWW/TheProject.html", author: "", date: "1991-01-01", tags: "research"},
    {title: "Architectural Styles and the Design of Network-based Software Architectures", url: "https://ics.uci.edu/~fielding/pubs/dissertation/top.htm", author: "Roy Fielding", date: "2000-01-01", tags: "research"},
    {title: "State of the Art Review on Hypermedia Issues and Applications", url: "https://web.archive.org/web/20240428215142/https://paul.luon.net/hypermedia/index.html", author: "", date: "2006-01-01", tags: "research"},
    {title: "How Primer changed JavaScript at Facebook", url: "https://youtu.be/BZmfCjtv6cM", author: "Makinde Adeagbo & Tom Occhino", date: "2010-01-01", tags: "research"},
    {title: "Hypermedia Controls: Feral to Formal", url: "https://dl.acm.org/doi/pdf/10.1145/3648188.3675127", author: "ACM HT'24", date: "2024-01-01", tags: "research"},
    {title: "Preserving REST-ful Visibility With Generalized Hypermedia Controls", url: "https://hypermedia.cs.montana.edu/papers/preserving-restful.pdf", author: "ACM SIGWEB", date: "2024-01-01", tags: "research"},
];

// Normalize into a common shape
interface ListItem {
    title: string;
    url: string;
    author: string;
    date: Date | null;
    tags: string;
    external: boolean;
}

const essayItems: ListItem[] = essays.map(e => ({
    title: e.frontmatter.title,
    url: e.url,
    author: e.frontmatter.authors?.join(', ') || '',
    date: e.frontmatter.created ? new Date(e.frontmatter.created) : null,
    tags: Array.isArray(e.frontmatter.tags) ? e.frontmatter.tags.join(' ') : '',
    external: false,
}));

const externalItems: ListItem[] = externalLinks.map(e => ({
    title: e.title,
    url: e.url,
    author: e.author,
    date: e.date ? new Date(e.date) : null,
    tags: e.tags,
    external: true,
}));

// Merge and sort by date (newest first, undated at end)
const allItems = [...essayItems, ...externalItems].sort((a, b) => {
    if (!a.date && !b.date) return 0;
    if (!a.date) return 1;
    if (!b.date) return 1;
    return b.date.getTime() - a.date.getTime();
});

// Only show tags that actually have items
const usedTags = new Set<string>();
for (const item of allItems) {
    item.tags.split(' ').filter(Boolean).forEach(t => usedTags.add(t));
}
const activeTags = tagDefs.filter(t => t.id === 'all' || usedTags.has(t.id));

const fmtDate = (d: Date | null) => {
    if (!d) return '';
    return d.toLocaleDateString('en-US', {year: 'numeric', month: 'short', day: 'numeric'});
};
---

<Layout title="Essays (Preview)" description="Preview of redesigned essays page.">
    <div id="content-wrapper" class="group/page">
        <main id="content-main-content" class="flex-1">
            <div class="w-full mx-auto px-4 sm:px-6 lg:px-8 flex justify-center max-w-[1440px]">
                <div class="pt-8 sm:pt-12 pb-24 flex-1 w-full relative max-w-4xl">

                    <!-- Breadcrumbs -->
                    <nav aria-label="Breadcrumb" class="mb-6">
                        <a href="/" class="sm:hidden inline-flex items-center gap-1 -ml-1 py-1.5 pr-2 text-sm text-neutral-500 dark:text-neutral-450 transition interact:underline interact:text-blue-700 dark:interact:text-blue-300 rounded-sm">
                            <i class="icon-[mdi--chevron-left] text-lg shrink-0" aria-hidden="true"></i>
                            <span class="truncate max-w-[30ch]">Home</span>
                        </a>
                        <ol class="hidden sm:flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-neutral-500 dark:text-neutral-450">
                            <li class="flex items-center gap-3">
                                <a href="/" class="transition interact:underline interact:text-blue-700 dark:interact:text-blue-300">Home</a>
                            </li>
                            <li class="flex items-center gap-3">
                                <span class="text-neutral-300 dark:text-neutral-700 select-none" aria-hidden="true">/</span>
                                <span class="font-bold text-neutral-700 dark:text-neutral-300" aria-current="page">Essays</span>
                            </li>
                        </ol>
                    </nav>

                    <div class="index-content prose prose-htmx prose-sm sm:prose-base dark:prose-invert max-w-none relative z-0">

                        <h1 class="mb-2">Essays</h1>
                        <p class="text-neutral-600 dark:text-neutral-400 text-lg mb-10">Perspectives on htmx, hypermedia, and simpler web development.</p>

                        <div class="not-prose">
                            <!-- Tag filter — separated tabs (desktop) -->
                            <div class="hidden sm:flex flex-wrap gap-2 mb-8">
                                {activeTags.map((tag, i) => (
                                    <label class:list={[
                                        "cursor-pointer select-none px-3 py-1.5 text-xs font-chicago whitespace-nowrap transition rounded-[3px]",
                                        "border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900",
                                        "text-neutral-500 dark:text-neutral-450",
                                        "interact:bg-neutral-100 dark:interact:bg-neutral-800 interact:border-neutral-300 dark:interact:border-neutral-700 interact:text-neutral-700 dark:interact:text-neutral-300",
                                        "has-checked:bg-neutral-150! has-checked:text-neutral-900! has-checked:border-neutral-400! has-checked:shadow-[inset_0_1px_2px_rgba(0,0,0,0.12)]!",
                                        "dark:has-checked:bg-neutral-800! dark:has-checked:text-neutral-100! dark:has-checked:border-neutral-600! dark:has-checked:shadow-[inset_0_1px_2px_rgba(0,0,0,0.4)]!",
                                    ]}>
                                        <input type="radio" name="tag" value={tag.id} class="sr-only" checked={i === 0}
                                               _="on change
                                                    show <.essay-row/> when my.value is 'all' or its @data-tags contains my.value
                                                    set #tag-select.value to my.value" />
                                        {tag.label}
                                    </label>
                                ))}
                            </div>

                            <!-- Tag filter — select (mobile) -->
                            <div class="sm:hidden flex items-center gap-3 mb-8">
                                <label for="tag-select" class="text-xs font-chicago text-neutral-500 dark:text-neutral-450 shrink-0">Filter by</label>
                                <select id="tag-select"
                                        class="flex-1 pl-3 pr-9 py-2 text-xs font-chicago rounded border border-neutral-300 dark:border-neutral-700 bg-white dark:bg-neutral-900 text-neutral-700 dark:text-neutral-300"
                                        _="on change
                                             show <.essay-row/> when my.value is 'all' or its @data-tags contains my.value
                                             for r in <input[name='tag']/> set r.checked to (r.value is my.value)">
                                    {activeTags.map(tag => (
                                        <option value={tag.id}>{tag.label}</option>
                                    ))}
                                </select>
                            </div>

                            <!-- Essay list -->
                            <div class="bg-white dark:bg-neutral-910 border border-neutral-200 dark:border-neutral-800 rounded-[4px] p-1.5">
                                <div class="flex flex-col gap-1">
                                    {allItems.map(item => (
                                        <a href={item.url}
                                           data-tags={item.tags}
                                           target={item.external ? '_blank' : undefined}
                                           rel={item.external ? 'noopener noreferrer' : undefined}
                                           class="essay-row group/essay flex flex-col sm:flex-row sm:items-center gap-0.5 sm:gap-4 px-3 py-2.5 sm:py-2 no-underline rounded-[3px] transition
                                                  text-neutral-800 dark:text-neutral-200
                                                  interact:bg-blue-700 interact:text-white dark:interact:bg-blue-350 dark:interact:text-black">

                                            <span class="flex-1 min-w-0 flex items-center gap-2">
                                                <span class="text-[13px] sm:text-sm leading-snug truncate">
                                                    {item.title}
                                                </span>
                                                {item.external && (
                                                    <i class="icon-[mdi--open-in-new] size-3 shrink-0 text-neutral-400 group-interact/essay:text-blue-200 dark:group-interact/essay:text-black transition" aria-label="External link"></i>
                                                )}
                                            </span>

                                            <span class="shrink-0 flex items-center gap-1.5 sm:gap-3 text-[11px] font-mono tabular-nums text-neutral-500 dark:text-neutral-450 group-interact/essay:text-blue-200 dark:group-interact/essay:text-black transition">
                                                {item.author && <span>{item.author}</span>}
                                                {item.author && item.date && <span aria-hidden="true">&middot;</span>}
                                                {item.date && <span class="sm:w-[12ch] sm:text-right">{fmtDate(item.date)}</span>}
                                            </span>

                                        </a>
                                    ))}
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </main>
    </div>

    <Footer slot="footer" />
</Layout>
