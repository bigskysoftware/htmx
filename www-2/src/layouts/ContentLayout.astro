---
import Layout from './Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import EssayHeader from '../components/EssayHeader.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Card from '../components/Card.astro';
import ThumbnailSvg from '../components/ThumbnailSvg.astro';
import type {ContentFile, ContentFolder} from '../lib/content';
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";


interface Props {
    file?: ContentFile;
    folder?: ContentFolder;
    headings?: any[];
    collection: string;
}

const {file, folder, headings = [], collection} = Astro.props;

const isIndex = !file;
const data = isIndex ? folder! : file;
const isEssay = !isIndex && collection === 'essays';
const hasSidebar = !!(folder?.subfolders?.length);

const {Content} = await data.render();
const {title, description, keywords} = data.frontmatter;

// Detail page only
const includeTableOfContents = !isIndex && headings.length > 0;
const includePagination = !isIndex && !!(file?.prev || file?.next);
const includeRightColumn = includeTableOfContents || includePagination;

// Index page only
const showCollectionCards = isIndex && ['docs', 'reference', 'patterns'].includes(collection);

const thumbnailModules = import.meta.glob('/src/assets/img/thumbnails/**/*.svg', {
    query: '?raw',
    import: 'default',
    eager: true
}) as Record<string, string>;

const getThumbnail = (path: string | undefined): string | null => {
    if (!path) return null;
    return thumbnailModules[`/src/assets/img/thumbnails/${path}`] || null;
};

const collectionCards = isIndex && folder ? folder.subfolders.sort((a, b) => a.id.localeCompare(b.id)) : [];
---

<Layout {title} {description} {keywords}>

    <Header slot="header">
        {hasSidebar && (
            <label slot="before-logo"
                   class="lg:hidden flex items-center justify-center size-10 cursor-pointer select-none rounded-xs text-neutral-600 dark:text-neutral-400 interact:text-neutral-800 dark:interact:text-neutral-100 sm:transition"
                   for="sidebar-toggle-mobile"
                   aria-label="Toggle Sidebar"
                   aria-controls="sidebar-nav"
                   role="button"
                   tabindex="0">
                <i class="size-5 icon-[mdi--menu-open]
                          transition-opacity duration-200
                          [html:has(#sidebar-toggle-mobile:checked)_&]:opacity-0"></i>
                <i class="size-5 icon-[mdi--menu-close]
                          absolute transition-opacity duration-200 opacity-0
                          [html:has(#sidebar-toggle-mobile:checked)_&]:opacity-100"></i>
            </label>
        )}
    </Header>

    {hasSidebar && <Sidebar folder={folder} file={file}/>}

    <div id="content-wrapper"
         class:list={["group/page", hasSidebar && "lg:pl-72"]}
         data-collection={collection}
         data-has-sidebar={hasSidebar}>
        <main id="main-content" class="flex-1">
            <div class="w-full mx-auto px-4 sm:px-6 lg:px-8 flex justify-center max-w-[1440px]">

                <div class:list={["pt-8 sm:pt-12 flex-1 w-full relative starting:opacity-0 delay-150 transition", isIndex ? "max-w-4xl" : "max-w-prose"]}>
                    <Breadcrumbs breadcrumbs={data.breadcrumbs} />

                    {isIndex ? (
                        <>
                            <div class="index-content prose prose-htmx prose-sm sm:prose-base dark:prose-invert max-w-none relative z-0">
                                <Content/>
                            </div>

                            {showCollectionCards && (
                                <div class="relative my-10 not-prose">
                                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 relative z-0">
                                        {collectionCards.map((item) => {
                                            const thumbnail = getThumbnail(item.frontmatter.thumbnail);

                                            return (
                                                <Card class:list={[
                                                    "group relative isolate flex flex-col overflow-hidden transition outline-hidden",
                                                    "interact:border-neutral-300 dark:interact:border-neutral-600",
                                                    "focus-within:ring-2 focus-within:ring-offset-2",
                                                    "focus-within:ring-neutral-500 dark:focus-within:ring-neutral-400"
                                                ]}>
                                                    <div class="relative h-40 lg:h-44 w-full flex items-center justify-center transition">
                                                        {thumbnail ? (
                                                            <ThumbnailSvg svg={thumbnail}/>
                                                        ) : (
                                                            <span class="text-7xl transition icon-[mdi--file-document-outline] text-neutral-400 dark:text-neutral-600 group-interact:text-neutral-600 dark:group-interact:text-neutral-300"></span>
                                                        )}
                                                    </div>

                                                    <div class:list={[
                                                        "flex flex-col p-5 bg-white/50 dark:bg-neutral-920/50 border-t border-neutral-150 dark:border-neutral-900 transition",
                                                        "group-interact:bg-neutral-100 dark:group-interact:bg-neutral-875",
                                                        "group-interact:border-neutral-300 dark:group-interact:border-neutral-600"
                                                    ]}>
                                                        <h2 class="font-bold text-lg text-neutral-700 dark:text-neutral-300 group-interact:text-black dark:group-interact:text-white transition mb-2">
                                                            <a href={item.url} class="outline-hidden">
                                                                {item.frontmatter.title}
                                                                <span class="absolute inset-0 z-10"></span>
                                                            </a>
                                                        </h2>
                                                        {item.frontmatter.description && (
                                                            <p class="text-sm text-neutral-600 dark:text-neutral-400 group-interact:text-neutral-950 dark:group-interact:text-neutral-50 leading-relaxed transition">
                                                                {item.frontmatter.description}
                                                            </p>
                                                        )}
                                                    </div>
                                                </Card>
                                            );
                                        })}
                                    </div>
                                </div>
                            )}
                        </>
                    ) : (
                        <article class="prose prose-htmx prose-sm sm:prose-base dark:prose-invert max-w-none">
                            <h1 set:html={title} />

                            {isEssay && (
                                <EssayHeader
                                    authors={file!.frontmatter.authors}
                                    created={file!.frontmatter.created}
                                    modified={file!.frontmatter.modified}
                                    fileId={file!.id}
                                />
                            )}

                            <slot name="before-content"/>

                            <Content/>

                            <slot name="after-content"/>

                            {includePagination && (
                                    <nav class="not-prose mt-16">
                                        <div class="grid gap-4 sm:grid-cols-2">
                                            {[
                                                {link: file!.prev, label: 'Previous', icon: 'icon-[mdi--chevron-left]'},
                                                {link: file!.next, label: 'Next', icon: 'icon-[mdi--chevron-right]', reverse: true}
                                            ].map(({link, label, icon, reverse}) =>
                                                link ? (
                                                    <Card class:list={[
                                                        "group relative isolate flex items-start gap-4 p-5 transition",
                                                        "interact:bg-neutral-75 dark:interact:bg-neutral-875",
                                                        "interact:border-neutral-400 dark:interact:border-neutral-600",
                                                        "focus-within:ring-2 focus-within:ring-offset-2",
                                                        "focus-within:ring-neutral-500"
                                                    ]}>
                                                        {!reverse && <i class:list={[icon, "text-2xl text-neutral-400 group-interact:text-neutral-600 dark:group-interact:text-neutral-200 transition shrink-0 mt-0.5"]}></i>}
                                                        <div class="flex-1 min-w-0">
                                                            {link.breadcrumbs.length > 2 && (
                                                                    <div class="text-xs font-medium text-neutral-600 dark:text-neutral-400 group-interact:text-neutral-700 dark:group-interact:text-neutral-200 mb-2 transition">
                                                                        {link.breadcrumbs.slice(1, -1).map(b => b.label).join(' / ')}
                                                                    </div>
                                                            )}
                                                            <h4 class="font-chicago text-neutral-700 dark:text-neutral-300 group-interact:text-neutral-900 dark:group-interact:text-white transition line-clamp-2"
                                                                set:html={link.frontmatter.title}></h4>
                                                            <a href={link.url} class="outline-hidden">
                                                                <span class="absolute inset-0 z-10"></span>
                                                                <span class="sr-only">{label}: {link.frontmatter.title}</span>
                                                            </a>
                                                            {link.frontmatter.description &&
                                                                    <div class="text-sm text-neutral-500 dark:text-neutral-500 group-interact:text-neutral-700 dark:group-interact:text-neutral-200 mt-2 line-clamp-2 leading-relaxed transition">{link.frontmatter.description}</div>}
                                                        </div>
                                                        {reverse && <i class:list={[icon, "text-2xl text-neutral-400 group-interact:text-neutral-600 dark:group-interact:text-neutral-200 transition shrink-0 mt-0.5"]}></i>}
                                                    </Card>
                                                ) : (
                                                    <div></div>
                                                )
                                            )}
                                        </div>
                                    </nav>
                            )}
                        </article>
                    )}
                </div>

                <!-- Right Column (Table of Contents) -->
                {includeRightColumn && (
                        <aside class:list={[
                    "hidden xl:flex xl:flex-col xl:w-60 shrink-0 xl:ml-16 self-start sticky top-(--header-height) max-h-[calc(100vh-var(--header-height))] pt-12 pr-4 overflow-hidden",
                    hasSidebar ? "xl:-me-16" : "xl:-me-[19rem]",
                ]}>
                            {includePagination && (
                                    <div class:list={["shrink-0", includeTableOfContents && "mb-8"]}>
                                        <div class="flex gap-2">
                                            {[
                                                {link: file!.prev, label: 'Previous', icon: 'icon-[mdi--chevron-left]'},
                                                {
                                                    link: file!.next,
                                                    label: 'Next',
                                                    icon: 'icon-[mdi--chevron-right]',
                                                    reverse: true
                                                }
                                            ].map(({link, label, icon, reverse}) => {
                                                return (
                                                        <Card
                                                                as={link ? 'a' : 'span'}
                                                                href={link?.url}
                                                                title={link?.frontmatter.title}
                                                                class:list={[
                                                                    "flex-1 group flex items-center gap-2 p-2 text-xs font-medium transition select-none",
                                                                    reverse && "flex-row-reverse",
                                                                    link
                                                                        ? "bg-white dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 interact:bg-neutral-75 dark:interact:bg-neutral-875 interact:border-neutral-400 dark:interact:border-neutral-600 interact:text-neutral-900 dark:interact:text-white"
                                                                        : "border-transparent bg-neutral-50 dark:bg-neutral-930 text-neutral-300 dark:text-neutral-700 cursor-not-allowed"
                                                                ]}>
                                                            <i class:list={[icon, "size-4", link ? "text-neutral-400 group-hover:text-neutral-600 dark:group-hover:text-neutral-200 transition" : "opacity-50"]}></i>
                                                            <span class="flex-1 inline-flex justify-center">{label}</span>
                                                        </Card>
                                                );
                                            })}
                                        </div>
                                    </div>
                            )}
                            {includeTableOfContents && (
                                    <>
                                        <h2 class="shrink-0 text-[0.675rem] font-sans tracking-wide uppercase text-neutral-500 mb-2">
                                            On this page
                                        </h2>
                                        <div class="flex-1 min-h-0 overflow-y-auto scrollbar-subtle mask-t-from-99% mask-b-from-98%">
                                            <TableOfContents {headings}/>
                                        </div>
                                    </>
                            )}
                        </aside>
                )}
            </div>
        </main>
    </div>

    <Footer slot="footer"
            class:list={[hasSidebar && "lg:pl-72"]}
            containerClass="px-4 sm:px-6 lg:px-12 xl:px-8"
            contentClass="mx-auto max-w-4xl"
    />
</Layout>
